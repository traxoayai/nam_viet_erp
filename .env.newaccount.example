# Template khi setup Gmail/Timo account. Ho tro 1 hoac nhieu account.
# Copy file nay sang .env.newaccount, dien gia tri, roi chay:
#   bash scripts/setup-new-account.sh

# ─── Cach 1: 1 account (legacy, giu nguyen) ───────────────────────────────
# GMAIL_USER_EMAIL=old@gmail.com
# GMAIL_REFRESH_TOKEN=1//0xxx

# ─── Cach 2: Nhieu account (khuyen dung) ──────────────────────────────────
GMAIL_ACCOUNT_1_EMAIL=a@gmail.com
GMAIL_ACCOUNT_1_REFRESH_TOKEN=1//0xxx
# GMAIL_ACCOUNT_2_EMAIL=b@gmail.com
# GMAIL_ACCOUNT_2_REFRESH_TOKEN=1//0yyy

# ─── Timo account (cho Portal QR — single primary account) ────────────────
TIMO_ACCOUNT_NO=1234567890
TIMO_ACCOUNT_NAME="CONG TY DUOC NAM VIET"

# ─── Gmail OAuth Client (chung cho tat ca accounts) ───────────────────────
GMAIL_CLIENT_ID=xxxxxxxxxx.apps.googleusercontent.com
GMAIL_CLIENT_SECRET=GOCSPX-xxxxxxxxxxxxxxxxxxxxxx

# ─── Pub/Sub Topic (chung) ─────────────────────────────────────────────────
PUBSUB_TOPIC=projects/nam-viet/topics/gmail-incoming

# ─── Supabase (neu chua co trong .env.dev / .env.local) ───────────────────
# SUPABASE_PROJECT_REF=iudkexocalqdhxuyjacu
# SUPABASE_ACCESS_TOKEN=sbp_xxx
# SUPABASE_SERVICE_ROLE_KEY=eyJxxx

# ─── Optional ─────────────────────────────────────────────────────────────
# GMAIL_PUSH_SECRET=8f28084745133470bc6bac0108791e79616f43c0
